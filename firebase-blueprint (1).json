{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a user of the platform with specific roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "seller", "agent", "buyer", "employee"] },
        "points": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "A game, software, or digital asset for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string", "enum": ["game", "software", "asset"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "archived", "draft"] },
        "inventory": { "type": "integer" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "imageUrl": { "type": "string" }
      },
      "required": ["sellerId", "name", "price", "category"]
    },
    "BusinessListing": {
      "title": "Business Listing",
      "description": "A business for sale in the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "businessName": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "monthlyRevenue": { "type": "number" },
        "monthlyProfit": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "businessName", "price"]
    },
    "Inquiry": {
      "title": "Business Inquiry",
      "description": "A message from a buyer to a seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "listingId": { "type": "string" },
        "listingName": { "type": "string" },
        "message": { "type": "string" },
        "buyerEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "sellerId", "listingId", "listingName", "message"]
    },
    "Property": {
      "title": "Real Estate Property",
      "description": "A property listing in the real estate module.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "title": { "type": "string" },
        "address": { "type": "string" },
        "price": { "type": "number" },
        "propertyType": { "type": "string", "enum": ["residential", "commercial", "land"] },
        "bedrooms": { "type": "integer" },
        "bathrooms": { "type": "integer" },
        "status": { "type": "string", "enum": ["listing", "under-contract", "closed"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["agentId", "title", "address", "price"]
    },
    "Task": {
      "title": "Gamified Task",
      "description": "A task assigned to an employee for project management.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed"] },
        "points": { "type": "integer" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "title", "points"]
    },
    "Transaction": {
      "title": "Payment Transaction",
      "description": "A record of a sale or escrow payment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "productId": { "type": "string" },
        "propertyId": { "type": "string" },
        "amount": { "type": "number" },
        "commission": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "escrow", "refunded"] },
        "type": { "type": "string", "enum": ["marketplace", "real-estate"] }
      },
      "required": ["buyerId", "sellerId", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "Users of the platform" },
    "/products/{id}": { "schema": "Product", "description": "Marketplace products" },
    "/businesses/{id}": { "schema": "BusinessListing", "description": "Business listings for sale" },
    "/inquiries/{id}": { "schema": "Inquiry", "description": "Messages regarding business listings" },
    "/properties/{id}": { "schema": "Property", "description": "Real estate listings" },
    "/tasks/{id}": { "schema": "Task", "description": "Workflow tasks" },
    "/transactions/{id}": { "schema": "Transaction", "description": "Sales and escrow records" }
  }
}
