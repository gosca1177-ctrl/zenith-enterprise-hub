rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == 'gosca1177@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'seller', 'agent', 'buyer', 'employee'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['sellerId', 'name', 'price', 'category']) &&
             data.sellerId == request.auth.uid &&
             data.name is string && data.name.size() <= 128 &&
             data.price is number && data.price >= 0 &&
             data.category in ['game', 'software', 'asset'];
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['sellerId', 'businessName', 'price']) &&
             data.sellerId == request.auth.uid &&
             data.businessName is string && data.businessName.size() <= 128 &&
             data.price is number && data.price >= 0;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['buyerId', 'sellerId', 'listingId', 'listingName', 'message']) &&
             data.buyerId == request.auth.uid &&
             data.message is string && data.message.size() <= 1000;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['creatorId', 'title', 'points']) &&
             data.creatorId == request.auth.uid &&
             data.title is string && data.title.size() <= 128 &&
             data.points is int && data.points >= 0;
    }

    // User Rules
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isVerified() && uid == request.auth.uid && isValidUser(incoming()) && !incoming().keys().hasAny(['points']);
      allow update: if isVerified() && uid == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) || isAdmin();
    }

    // Product Rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isVerified() && (
        (isOwner(existing().sellerId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'inventory', 'status'])) ||
        isAdmin()
      );
      allow delete: if isVerified() && (isOwner(existing().sellerId) || isAdmin());
    }

    // Business Rules
    match /businesses/{bizId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(bizId) && isValidBusiness(incoming());
      allow update: if isVerified() && (isOwner(existing().sellerId) || isAdmin());
      allow delete: if isVerified() && (isOwner(existing().sellerId) || isAdmin());
    }

    // Inquiry Rules
    match /inquiries/{inqId} {
      allow read: if isVerified() && (isOwner(existing().sellerId) || isOwner(existing().buyerId) || isAdmin());
      allow create: if isVerified() && isValidId(inqId) && isValidInquiry(incoming());
    }

    // Property Rules
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(propertyId); // Simplified for prototype
      allow update: if isVerified() && (isOwner(existing().agentId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Task Rules
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidTask(incoming());
      allow update: if isVerified() && (
        (isOwner(existing().creatorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'status', 'points', 'assigneeId'])) ||
        (isOwner(existing().assigneeId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
    }

    // Transaction Rules (Escrow)
    match /transactions/{id} {
      allow read: if isSignedIn() && (isOwner(existing().buyerId) || isOwner(existing().sellerId) || isAdmin());
      allow create: if isVerified() && incoming().buyerId == request.auth.uid;
      allow update: if isAdmin(); // Only admins/system can finalize transactions
    }
  }
}
